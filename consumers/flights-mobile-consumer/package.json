{
  "name": "booking-flights-mobile-consumer",
  "version": "1.0.0",
  "description": "Booking.com mobile consumer for the Flights REST API",
  "scripts": {
    "test": "jest --testPathPattern=tests/",
    "publish:pacts": "pact-broker publish ./pacts --consumer-app-version=$GIT_COMMIT --branch=$GIT_BRANCH --broker-base-url=$PACT_BROKER_BASE_URL --broker-token=$PACT_BROKER_TOKEN"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^13.1.3",
    "@pact-foundation/pact-node": "^10.18.0",
    "jest": "^29.7.0",
    "dotenv": "^16.3.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  }
}
