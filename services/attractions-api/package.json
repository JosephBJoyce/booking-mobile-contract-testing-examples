{
  "name": "booking-attractions-api",
  "version": "1.0.0",
  "description": "Booking.com Attractions GraphQL API — BDCT provider",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --testPathPattern=tests/ --forceExit",
    "test:bdct": "jest --testPathPattern=tests/provider.bdct.test.js --forceExit",
    "publish:contract": "pact-broker publish-provider-contract openapi/attractions-api.yml --provider booking-attractions-api --provider-app-version=$GIT_COMMIT --branch=$GIT_BRANCH --broker-base-url=$PACT_BROKER_BASE_URL --broker-token=$PACT_BROKER_TOKEN --verification-results=./verification-results.json --verification-results-content-type=application/json --verifier=jest"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^13.1.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000
  }
}
